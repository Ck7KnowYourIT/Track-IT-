}

/* NAVBAR */

.nav{
display:flex;
align-items:center;
justify-content:space-between;
margin-bottom:50px;
}

.brand{
display:flex;
align-items:center;
gap:12px;
text-decoration:none;
color:var(--text);
font-weight:700;
}

.brand img{
height:30px;
}

.navlinks{
display:flex;
gap:20px;
}

.navlinks a{
text-decoration:none;
color:var(--text);
font-weight:500;
font-size:14px;
}

/* HERO */

.hero{
max-width:760px;
margin-bottom:60px;
}

.hero h1{
font-size:40px;
margin-bottom:15px;
}

.hero p{
font-size:18px;
color:var(--muted);
line-height:1.6;
}

.cta{
margin-top:25px;
}

.cta a{
display:inline-block;
background:var(--accent);
color:white;
padding:14px 20px;
border-radius:8px;
text-decoration:none;
font-weight:700;
}

/* SECTION */

.sectiontitle{
font-size:18px;
margin-bottom:20px;
color:var(--muted);
font-weight:700;
}

/* CARDS */

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:20px;
margin-bottom:50px;
}

.card{
background:var(--card);
border:1px solid var(--border);
border-radius:10px;
padding:24px;
}

.card h3{
margin-top:0;
margin-bottom:10px;
}

.card p{
color:var(--muted);
line-height:1.6;
}

.card .btn{
margin-top:15px;
display:inline-block;
background:var(--accent);
color:white;
padding:10px 16px;
border-radius:6px;
text-decoration:none;
font-weight:600;
font-size:14px;
}

/* STEPS */

.steps{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
gap:20px;
margin-bottom:50px;
}

.step{
background:var(--card);
border:1px solid var(--border);
border-radius:10px;
padding:20px;
}

.step b{
display:block;
margin-bottom:5px;
}

/* TRUST */

.trust{
border:1px solid var(--border);
background:white;
padding:20px;
border-radius:10px;
text-align:center;
color:var(--muted);
}

/* FOOTER */

.footer{
margin-top:60px;
font-size:13px;
color:#64748b;
text-align:center;
}

</style>
